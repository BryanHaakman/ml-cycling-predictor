# Virtual environment
.venv/

# Python
__pycache__/
*.py[cod]

# Database (exported to data/exports/latest/ instead)
data/cache.db
data/cache.db-shm
data/cache.db-wal

# DB snapshot is tracked (used by nightly workflow)
!data/db_snapshot.sql.gz

# Feature cache (regenerated by scripts/precompute_features.py)
data/*_cache.parquet

# Trained model artifacts (regenerated by scripts/train.py)
models/trained/

# Jupyter
.ipynb_checkpoints/

# OS / IDE
.DS_Store
.vscode/
.idea/

# Logs
*.log

# Pinnacle API key cache (extracted from JS bundle, rotates)
data/.pinnacle_key_cache

# Data exports (all, including latest — regenerated by scripts/export_data.py)
data/exports/

# Environment secrets
.env

# Pinnacle session state (machine-managed, contains session token)
data/.pinnacle_session_state.json
